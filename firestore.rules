rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: ipos
    // Document ID: auto-generated or custom
    // Fields: name, symbol, sector, price, units, openingDate, closingDate, status, type, minUnits, maxUnits, issueManager
    //
    // Collection: countdown
    // Document ID: main
    // Fields: targetDate, title, isActive
    //
    // Collection: users
    // Document ID: Firebase Auth UID
    // Fields: email, savedBoids, createdAt, role
    //
    // Collection: oversubscription
    // Document ID: companyId
    // Fields: name, times, applicants, units, lastUpdated
    //
    // Collection: predictions
    // Document ID: auto-generated
    // Fields: ipoName, units, chance, userId, timestamp
    //
    // Collection: stats
    // Document ID: auto-generated or custom
    // Fields: totalPredictions, totalUsers
    //
    // Collection: ipo_results_list
    // Document ID: auto-generated or custom
    // Fields: name, companyId, status
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         (request.auth.token.email == "earnrealcashnepal@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email']) &&
             data.email is string &&
             (!('savedBoids' in data) || data.savedBoids is list) &&
             (!('role' in data) || data.role in ['user', 'admin']);
    }

    function isValidIpo(data) {
      return data.keys().hasAll(['name', 'symbol', 'price', 'status']) &&
             data.name is string && data.symbol is string && data.price is number;
    }

    function isValidCountdown(data) {
      return data.keys().hasAll(['targetDate', 'title']) &&
             data.targetDate is string && data.title is string;
    }

    function isValidOversubscription(data) {
      return data.keys().hasAll(['name', 'times', 'applicants', 'units']) &&
             data.name is string && data.times is number && data.applicants is number && data.units is number;
    }

    function isValidPrediction(data) {
      return data.keys().hasAll(['ipoName', 'units', 'chance', 'userId', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.ipoName is string &&
             data.units is number &&
             data.chance is number;
    }

    function isValidIpoResult(data) {
      return data.keys().hasAll(['name', 'companyId']) &&
             data.name is string && data.companyId is string;
    }

    function isValidStat(data) {
      return (!('totalPredictions' in data) || data.totalPredictions is number) &&
             (!('totalUsers' in data) || data.totalUsers is number);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /ipo_results_list/{ipoId} {
      allow read: if true;
      allow write: if isAdmin() && isValidIpoResult(request.resource.data);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                      (request.resource.data.role == 'user' || isAdmin());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && 
                      (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /ipos/{ipoId} {
      allow read: if true;
      allow write: if isAdmin() && isValidIpo(request.resource.data);
    }

    match /countdown/{docId} {
      allow read: if true;
      allow write: if isAdmin() && isValidCountdown(request.resource.data);
    }

    match /oversubscription/{companyId} {
      allow read: if true;
      allow write: if isAdmin() && isValidOversubscription(request.resource.data);
    }

    match /predictions/{predictionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidPrediction(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /stats/{statId} {
      allow read: if true;
      allow write: if isAdmin() || isAuthenticated(); // Allow users to increment stats if app logic requires
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
